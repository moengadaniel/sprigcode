{
  "name": "@sprigcode/core",
  "version": "0.1.2",
  "description": "Core engine for typed semantic code-edit transactions.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moengadaniel/sprigcode.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/moengadaniel/sprigcode/issues"
  },
  "homepage": "https://github.com/moengadaniel/sprigcode/tree/main/packages/core#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
