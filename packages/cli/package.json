{
  "name": "@sprigcode/cli",
  "version": "0.1.0",
  "description": "CLI for typed semantic code-edit transactions.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eat-apples/sprigcode.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/eat-apples/sprigcode/issues"
  },
  "homepage": "https://github.com/eat-apples/sprigcode/tree/main/packages/cli#readme",
  "type": "module",
  "bin": {
    "sprigcode": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sprigcode/core": "workspace:*",
    "@sprigcode/schema": "workspace:*",
    "@sprigcode/ts": "workspace:*"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
