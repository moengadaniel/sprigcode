{
  "name": "sprigcode",
  "private": true,
  "version": "0.1.0",
  "description": "Typed semantic code-edit transactions for tools and agents.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eat-apples/sprigcode.git"
  },
  "bugs": {
    "url": "https://github.com/eat-apples/sprigcode/issues"
  },
  "homepage": "https://github.com/eat-apples/sprigcode#readme",
  "files": [
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "GOVERNANCE.md",
    "ROADMAP.md",
    "SECURITY.md"
  ],
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "corepack pnpm -r build",
    "lint": "eslint \"packages/**/*.ts\"",
    "typecheck": "tsc -b --pretty false",
    "test": "corepack pnpm -r test",
    "test:golden": "corepack pnpm --filter @sprigcode/ts test:golden",
    "test:smoke": "corepack pnpm build && node scripts/smoke.mjs",
    "test:npm-smoke": "corepack pnpm build && node scripts/npm-smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "ajv": "^8.17.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
